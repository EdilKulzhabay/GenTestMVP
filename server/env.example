# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/edu-ai-test-platform

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# WhatsApp Bot (отдельный сервис whatsapp-bot/)
WHATSAPP_BOT_URL=http://localhost:5112
WHATSAPP_BOT_API_KEY=optional_secret
WHATSAPP_ENABLED=true
WHATSAPP_SEND_TIMEOUT_MS=2500

# Telegram (бот — отдельный сервис telegram-bot/)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_ENABLED=true
TELEGRAM_SEND_TIMEOUT_MS=2000
TELEGRAM_API_TIMEOUT_MS=2000

# CORS Configuration (optional)
CORS_ORIGIN=*

# Frontend / OAuth redirect (optional)
# FRONTEND_URL — куда редиректим после Google OAuth callback по умолчанию (всегда в allowlist).
# OAUTH_ALLOWED_ORIGINS — доп. allowlist через запятую. Поддерживает:
#   • точные origin-ы:   https://app.example.com
#   • wildcard-поддомены: *.onrender.com  (только https, корневой домен не матчится)
# В non-production также автоматически разрешены localhost/127.0.0.1 и приватные LAN-сети.
FRONTEND_URL=http://localhost:5173
# OAUTH_ALLOWED_ORIGINS=*.onrender.com,https://staging.example.com

# AI Service Configuration
OPENAI_API_KEY=your_openai_api_key
